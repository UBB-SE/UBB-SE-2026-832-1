<Page
    x:Class="WinUI.Views.MealsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:WinUI.ViewModels"
    xmlns:dtos="using:ClassLibrary.DTOs">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
            <TextBox PlaceholderText="Search meal..."
                     Width="250"
                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <Button Content="Search" Command="{Binding SearchCommand}"/>

            <Button Content="Filters">
                <Button.Flyout>
                    <Flyout>
                        <StackPanel Padding="10" Spacing="5">
                            <CheckBox Content="Vegan" IsChecked="{Binding IsVegan, Mode=TwoWay}"/>
                            <CheckBox Content="Keto" IsChecked="{Binding IsKeto, Mode=TwoWay}"/>
                            <CheckBox Content="Gluten Free" IsChecked="{Binding IsGlutenFree, Mode=TwoWay}"/>
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
        </StackPanel>

        <ListView ItemsSource="{Binding Meals}"
                  Grid.Row="1"
                  SelectedItem="{Binding SelectedMeal, Mode=TwoWay}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="dtos:FoodItemDto">
                    <Grid Padding="10" Margin="5" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                          CornerRadius="10" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{x:Bind Name}" FontSize="17" FontWeight="SemiBold"/>
                            <TextBlock Opacity="0.75">
                                <Run Text="{x:Bind Calories}" /> <Run Text=" kcal" />
                            </TextBlock>

                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                                <Border Background="#2E7D32" CornerRadius="12" Padding="8,2"
                                        Visibility="{x:Bind IsVegan, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Vegan" Foreground="White" FontSize="11"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1" 
                                Command="{Binding ElementName=listMeals, Path=DataContext.ToggleFavoriteCommand}"
                                CommandParameter="{Binding}"
                                 
                                Foreground="Gold" Background="Transparent"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
            <Button Content="Prev" Command="{Binding PrevPageCommand}"/>
            <TextBlock Text="{Binding PageDisplay}" VerticalAlignment="Center"/>
            <Button Content="Next" Command="{Binding NextPageCommand}"/>
        </StackPanel>
    </Grid>
</Page>

<!-- Content="{x:Bind IsFavoriteIcon}" use this in the Button to display the favorite icon when it works-->