<Page
    x:Class="WinUI.Views.UserDataView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F5F5F5">

    <Grid>
        <Border Width="450" Background="White" CornerRadius="8" Padding="40" 
                HorizontalAlignment="Center" VerticalAlignment="Center"
                BorderBrush="#CCCCCC" BorderThickness="1">
            <StackPanel Spacing="16">
                <TextBlock Text="User Data" FontSize="28" FontWeight="SemiBold" 
                           Foreground="Black" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <StackPanel Spacing="8">
                    <TextBlock Text="Weight (kg)" Foreground="Black" />
                    <NumberBox Value="{x:Bind ViewModel.Weight, Mode=TwoWay}" 
                               Foreground="Black" BorderBrush="#999999" SpinButtonPlacementMode="Hidden" />
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="Height (cm)" Foreground="Black" />
                    <NumberBox Value="{x:Bind ViewModel.Height, Mode=TwoWay}" 
                               Foreground="Black" BorderBrush="#999999" SpinButtonPlacementMode="Hidden" />
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="Birthdate" Foreground="Black" />
                    <CalendarDatePicker Date="{x:Bind ViewModel.SelectedDate, Mode=TwoWay}" 
                                        Foreground="Black" BorderBrush="#999999" HorizontalAlignment="Stretch" />
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="Gender" Foreground="Black" />
                    <TextBox Text="{x:Bind ViewModel.Gender, Mode=TwoWay}" 
                             Foreground="Black" BorderBrush="#999999" HorizontalAlignment="Stretch" />
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="Health Goal" Foreground="Black" />
                    <TextBox Text="{x:Bind ViewModel.Goal, Mode=TwoWay}" 
                             Foreground="Black" BorderBrush="#999999" HorizontalAlignment="Stretch" />
                </StackPanel>

                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" 
                           Foreground="Red" HorizontalAlignment="Center" TextWrapping="Wrap" />

                <Button Content="Save Details" Command="{x:Bind ViewModel.SaveDataCommand}" 
                        Background="#0066CC" Foreground="White" HorizontalAlignment="Stretch" Margin="0,20,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>