<Page
    x:Class="WinUI.Views.UserDataView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F5F5F5">

	<Grid>
		<Border Width="450" Background="White" CornerRadius="8" Padding="40"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                BorderBrush="#E0E0E0" BorderThickness="1">
			<StackPanel Spacing="16">
				<TextBlock Text="User Data" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

				<StackPanel Spacing="8">
					<TextBlock Text="Weight (kg)" />
					<NumberBox Value="{x:Bind ViewModel.Weight, Mode=TwoWay}" PlaceholderText="0" SpinButtonPlacementMode="Hidden" />
				</StackPanel>

				<StackPanel Spacing="8">
					<TextBlock Text="Height (cm)" />
					<NumberBox Value="{x:Bind ViewModel.Height, Mode=TwoWay}" PlaceholderText="0" SpinButtonPlacementMode="Hidden" />
				</StackPanel>

				<StackPanel Spacing="8">
					<TextBlock Text="Birthdate" />
					<CalendarDatePicker Date="{x:Bind ViewModel.Birthdate, Mode=TwoWay}" HorizontalAlignment="Stretch" />
				</StackPanel>

				<StackPanel Spacing="8">
					<TextBlock Text="Gender" />
					<ComboBox ItemsSource="{x:Bind ViewModel.Genders}" SelectedItem="{x:Bind ViewModel.SelectedGender, Mode=TwoWay}" PlaceholderText="Select gender" HorizontalAlignment="Stretch" />
				</StackPanel>

				<StackPanel Spacing="8">
					<TextBlock Text="Health Goal" />
					<ComboBox ItemsSource="{x:Bind ViewModel.Goals}" SelectedItem="{x:Bind ViewModel.SelectedGoal, Mode=TwoWay}" PlaceholderText="Select health goal" HorizontalAlignment="Stretch" />
				</StackPanel>

				<Button Content="Save Details" Command="{x:Bind ViewModel.SaveDataCommand}"
                        Background="#0066CC" Foreground="White" HorizontalAlignment="Stretch" Margin="0,20,0,0"/>
			</StackPanel>
		</Border>
	</Grid>
</Page>
