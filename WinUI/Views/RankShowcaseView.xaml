<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinUI.Views.RankShowcaseView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:ClassLibrary.Models"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24,20,28,40" Spacing="24">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        Text="Rank Showcase"
                        Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock
                        Text="Your dynamic level and achievement history"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <Button
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Style="{StaticResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.RefreshCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Refresh" />
                        <TextBlock Text="Refresh" />
                    </StackPanel>
                </Button>
            </Grid>

            <Border
                Background="{ThemeResource AccentFillColorDefaultBrush}"
                CornerRadius="12"
                Padding="28,24">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                    <StackPanel
                        Grid.Row="0"
                        Orientation="Horizontal"
                        Spacing="16"
                        VerticalAlignment="Center">
                        <Border
                            Width="52"
                            Height="52"
                            CornerRadius="26"
                            Background="White"
                            Opacity="0.15">
                            <FontIcon
                                Glyph="&#xE8A4;"
                                FontSize="28"
                                Foreground="White"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock
                                Text="Your Rank"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="White"
                                Opacity="0.75" />
                            <TextBlock
                                Text="{x:Bind ViewModel.LevelDisplayLine, Mode=OneWay}"
                                Style="{StaticResource TitleLargeTextBlockStyle}"
                                Foreground="White" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel
                        Grid.Row="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        Margin="0,20,0,0">
                        <FontIcon Glyph="&#xE735;" FontSize="14" Foreground="White" Opacity="0.75" VerticalAlignment="Center" />
                        <TextBlock
                            Text="{x:Bind ViewModel.UnlockedAchievementsDisplay, Mode=OneWay}"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Foreground="White"
                            VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock
                        Grid.Row="2"
                        Text="{x:Bind ViewModel.NextRankInfo, Mode=OneWay}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="White"
                        Opacity="0.85"
                        TextWrapping="Wrap"
                        Margin="0,12,0,0" />
                </Grid>
            </Border>

            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock
                        Text="Rank Tiers"
                        Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock
                        Text="Beginner (0 achievements)  ·  Trainee (1 achievement)  ·  Apprentice (2 achievements)  ·  Gym Novice (3 achievements)  ·  Gym Enthusiast (5 achievements)  ·  Athlete (7 achievements)  ·  Elite (10 achievements)"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <StackPanel Spacing="4">
                <TextBlock
                    Text="Achievement Showcase"
                    Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock
                    Text="Locked goals stay listed so you can always see what is next."
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <ProgressRing
                Width="28"
                Height="28"
                HorizontalAlignment="Left"
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.LoadingVisibility, Mode=OneWay}" />

            <TextBlock
                Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                Foreground="Red" />

            <ItemsControl ItemsSource="{x:Bind ViewModel.ShowcaseAchievements, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:AchievementShowcaseItem">
                        <Border
                            Margin="0,0,0,8"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Grid
                                    Grid.Column="0"
                                    Width="44"
                                    Height="44"
                                    VerticalAlignment="Center">
                                    <Border
                                        x:Load="{x:Bind IsUnlocked, Mode=OneWay}"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                        CornerRadius="22">
                                        <FontIcon
                                            Glyph="&#xE8FB;"
                                            FontSize="22"
                                            Foreground="White"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />
                                    </Border>
                                    <Border
                                        x:Load="{x:Bind IsLocked, Mode=OneWay}"
                                        Background="{ThemeResource CardStrokeColorDefaultBrush}"
                                        CornerRadius="22">
                                        <FontIcon
                                            Glyph="&#xE72E;"
                                            FontSize="22"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                    <TextBlock
                                        Text="{x:Bind Title}"
                                        Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock
                                        Text="{x:Bind Description}"
                                        Style="{StaticResource BodyTextBlockStyle}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,2,0,0">
                                        <FontIcon
                                            Glyph="&#xE946;"
                                            FontSize="10"
                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                            VerticalAlignment="Center" />
                                        <TextBlock
                                            Text="{x:Bind Criteria}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
