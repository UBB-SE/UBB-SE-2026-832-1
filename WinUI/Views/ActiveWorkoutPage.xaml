<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinUI.Views.ActiveWorkoutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:ClassLibrary.Models"
    xmlns:extensions="using:WinUI.Extensions"
    mc:Ignorable="d"
    Loaded="Page_Loaded"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <extensions:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <Page.Transitions>
        <TransitionCollection>
            <NavigationThemeTransition />
        </TransitionCollection>
    </Page.Transitions>

    <Grid RowDefinitions="Auto,*">
        <Border
            Grid.Row="0"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1"
            Padding="24,20">
            <Grid ColumnDefinitions="*,Auto">

                <StackPanel Spacing="4" VerticalAlignment="Center">
                    <TextBlock
                        Text="WORKOUT TIME"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        CharacterSpacing="100" />
                    <TextBlock
                        Text="{Binding WorkoutElapsedDisplay, Mode=OneWay}"
                        FontSize="52"
                        FontWeight="Bold"
                        FontFamily="Consolas"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                        CharacterSpacing="20" />
                    <TextBlock
                        Text="{Binding SelectedTemplate.Name, Mode=OneWay}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Visibility="{Binding IsWorkoutStarted, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>

                <Button
                    Grid.Column="1"
                    Style="{StaticResource AccentButtonStyle}"
                    VerticalAlignment="Center"
                    Command="{Binding FinishWorkoutCommand}"
                    CommandParameter="{Binding ClientId}"
                    IsEnabled="{Binding IsWorkoutStarted, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ProgressRing
                            IsActive="{Binding IsFinishing, Mode=OneWay}"
                            Visibility="{Binding IsFinishing, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Width="16" Height="16" />
                        <FontIcon Glyph="&#xE73E;" FontSize="14" />
                        <TextBlock Text="Finish Workout" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer
            Grid.Row="1"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled">
            <StackPanel Padding="24,24,28,40" Spacing="24">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition IsStaggeringEnabled="True" />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <InfoBar
                    IsOpen="{Binding HasError, Mode=OneWay}"
                    Severity="Error"
                    Title="Error"
                    Message="{Binding ErrorMessage, Mode=OneWay}" />

                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="24">
                    <StackPanel Spacing="16">
                        <Grid>
                            <TextBlock
                                Text="Available Workouts for You"
                                Style="{StaticResource SubtitleTextBlockStyle}"
                                VerticalAlignment="Center" />
                            <ProgressRing
                                HorizontalAlignment="Right"
                                IsActive="{Binding IsLoadingWorkouts, Mode=OneWay}"
                                Visibility="{Binding IsLoadingWorkouts, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Width="20" Height="20" />
                        </Grid>

                        <Button HorizontalAlignment="Stretch" x:Name="TargetGoalsButton">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE74C;" FontSize="14" />
                                <TextBlock Text="Select Target Goals" />
                            </StackPanel>
                            <Button.Flyout>
                                <Flyout Placement="Bottom">
                                    <StackPanel Spacing="12" MinWidth="260" Padding="8">
                                        <TextBlock
                                            Text="Select your target goal"
                                            Style="{StaticResource BodyStrongTextBlockStyle}" />

                                        <RadioButton
                                            Content="Weight Loss — HIIT Fat Burner"
                                            GroupName="TargetGoal"
                                            Tag="HIIT Fat Burner"
                                            Checked="GoalRadioButton_Checked" />

                                        <RadioButton
                                            Content="Muscle Gain — Full Body Mass"
                                            GroupName="TargetGoal"
                                            Tag="Full Body Mass"
                                            Checked="GoalRadioButton_Checked" />

                                        <RadioButton
                                            Content="Raw Strength — Full Body Power"
                                            GroupName="TargetGoal"
                                            Tag="Full Body Power"
                                            Checked="GoalRadioButton_Checked" />

                                        <RadioButton
                                            Content="Muscular Endurance — Endurance Circuit"
                                            GroupName="TargetGoal"
                                            Tag="Endurance Circuit"
                                            Checked="GoalRadioButton_Checked" />

                                        <Button
                                            Style="{StaticResource AccentButtonStyle}"
                                            HorizontalAlignment="Stretch"
                                            Click="ApplyGoalsButton_Click">
                                            <TextBlock Text="Apply" />
                                        </Button>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>

                        <ItemsRepeater
                            ItemsSource="{Binding AvailableWorkouts, Mode=OneWay}"
                            Visibility="{Binding IsLoadingWorkouts, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:WorkoutTemplate">
                                    <Border
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="4"
                                        Padding="12,8"
                                        Margin="0,2">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE14C;" FontSize="12"
                                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                            <TextBlock Text="{Binding Name}"
                                                       Style="{StaticResource BodyTextBlockStyle}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>

                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="24">
                    <StackPanel Spacing="12">
                        <Grid>
                            <TextBlock
                                Text="My Saved Workouts"
                                Style="{StaticResource SubtitleTextBlockStyle}"
                                VerticalAlignment="Center" />
                            <Button
                                HorizontalAlignment="Right"
                                Click="CreateCustomWorkout_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                                    <TextBlock Text="Create Custom" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <TextBlock
                            Text="No saved workouts yet. Create one or ask your trainer to assign a routine."
                            Style="{StaticResource BodyTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Visibility="{Binding HasCustomWorkouts, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}" />

                        <ItemsRepeater
                            ItemsSource="{Binding CustomWorkouts, Mode=OneWay}"
                            Visibility="{Binding HasCustomWorkouts, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:WorkoutTemplate">
                                    <Border
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="4"
                                        Padding="12,8"
                                        Margin="0,2">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE71E;" FontSize="12"
                                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                                <TextBlock Text="{Binding Name}"
                                                           Style="{StaticResource BodyTextBlockStyle}" />
                                                <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                        CornerRadius="999"
                                                        Padding="8,2">
                                                    <TextBlock Text="{Binding Type}"
                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                </Border>
                                            </StackPanel>
                                            <Button
                                                Grid.Column="1"
                                                Content="Start"
                                                Style="{StaticResource AccentButtonStyle}"
                                                Tag="{Binding}"
                                                Click="StartCustomWorkout_Click" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>

                <Button
                    Content="Open focus mode (fullscreen summary)"
                    HorizontalAlignment="Stretch"
                    Click="OpenFocusMode_Click"
                    Visibility="{Binding IsWorkoutStarted, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <ItemsRepeater
                    ItemsSource="{Binding ExerciseRows, Mode=OneWay}"
                    Visibility="{Binding IsWorkoutStarted, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Expander
                                IsExpanded="True"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                CornerRadius="8"
                                Margin="0,0,0,12">

                                <Expander.Header>
                                    <Grid ColumnDefinitions="*,Auto" Padding="0,8">
                                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xE14C;" FontSize="16"
                                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                            <TextBlock
                                                Text="{Binding ExerciseName}"
                                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                                VerticalAlignment="Center" />
                                            <TextBlock
                                                Text="{Binding MuscleGroup}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                VerticalAlignment="Center" />
                                        </StackPanel>
                                        <Border
                                            Grid.Column="1"
                                            Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                                            BorderBrush="{ThemeResource SystemFillColorCautionBrush}"
                                            BorderThickness="1" CornerRadius="4" Padding="8,4"
                                            Visibility="{Binding IsSystemAdjusted, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            VerticalAlignment="Center">
                                            <ToolTipService.ToolTip>
                                                <ToolTip>
                                                    <StackPanel Spacing="4" MaxWidth="300">
                                                        <TextBlock Text="System Adjusted" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                                        <TextBlock Text="{Binding AdjustmentNote, Mode=OneWay}"
                                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </ToolTip>
                                            </ToolTipService.ToolTip>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE7BA;" FontSize="12"
                                                          Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                                                <TextBlock Text="System Adjusted"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Expander.Header>

                                <Expander.Content>
                                    <StackPanel Spacing="4" Padding="0,8,0,12">
                                        <Grid ColumnDefinitions="32,*,120,120,Auto" Padding="0,0,0,8">
                                            <TextBlock Text="#" Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="Exercise"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Grid.Column="2" Text="Reps"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Grid.Column="3" Text="Weight (kg)"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       HorizontalAlignment="Center" />
                                        </Grid>

                                        <ItemsRepeater ItemsSource="{Binding Sets, Mode=OneWay}">
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="4" Padding="0,6" Margin="0,2">
                                                        <Grid ColumnDefinitions="32,*,120,120,Auto" ColumnSpacing="8">
                                                            <Border
                                                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                                CornerRadius="12" Width="24" Height="24"
                                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <TextBlock
                                                                    Text="{Binding SetIndex}"
                                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                                    Foreground="White"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center" />
                                                            </Border>
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                                    <Run Text="Target: " />
                                                                    <Run Text="{Binding TargetReps}" />
                                                                    <Run Text=" reps" />
                                                                </TextBlock>
                                                            </StackPanel>
                                                            <NumberBox
                                                                Grid.Column="2"
                                                                Value="{Binding ActualRepsValue, Mode=TwoWay}"
                                                                Minimum="0" Maximum="999"
                                                                SpinButtonPlacementMode="Hidden"
                                                                PlaceholderText="Reps"
                                                                IsEnabled="{Binding IsCompleted, Mode=OneWay}"
                                                                HorizontalAlignment="Stretch" />
                                                            <NumberBox
                                                                Grid.Column="3"
                                                                Value="{Binding ActualWeightValue, Mode=TwoWay}"
                                                                Minimum="0" Maximum="9999" SmallChange="0.5"
                                                                SpinButtonPlacementMode="Hidden"
                                                                PlaceholderText="kg"
                                                                IsEnabled="{Binding IsCompleted, Mode=OneWay}"
                                                                HorizontalAlignment="Stretch" />
                                                            <FontIcon
                                                                Grid.Column="4"
                                                                Glyph="&#xE73E;" FontSize="16"
                                                                Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                                                VerticalAlignment="Center"
                                                                Visibility="{Binding IsCompleted, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                    </StackPanel>
                                </Expander.Content>
                            </Expander>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <StackPanel
                    Spacing="12"
                    Visibility="{Binding IsWorkoutStarted, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Notifications" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <ItemsRepeater ItemsSource="{Binding Notifications, Mode=OneWay}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:Notification">
                                <Border
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                                        <FontIcon Glyph="&#xE7BA;" FontSize="24"
                                                  Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                                  VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <TextBlock Text="{Binding Message}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <Button
                                            Grid.Column="2"
                                            Style="{StaticResource AccentButtonStyle}"
                                            VerticalAlignment="Center"
                                            Tag="{Binding}"
                                            Click="ConfirmDeloadButton_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                                <TextBlock Text="Confirm Deload" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <Button
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Command="{Binding FinishWorkoutCommand}"
                    CommandParameter="{Binding ClientId}"
                    IsEnabled="{Binding IsWorkoutStarted, Mode=OneWay}"
                    Visibility="{Binding IsWorkoutStarted, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ProgressRing
                            IsActive="{Binding IsFinishing, Mode=OneWay}"
                            Visibility="{Binding IsFinishing, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Width="16" Height="16" />
                        <FontIcon Glyph="&#xE73E;" FontSize="14" />
                        <TextBlock Text="Finish Workout" />
                    </StackPanel>
                </Button>

                <Button
                    HorizontalAlignment="Stretch"
                    Command="{Binding RepeatWorkoutCommand}"
                    CommandParameter="{Binding ClientId}"
                    Visibility="{Binding IsWorkoutStarted, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72C;" FontSize="14" />
                        <TextBlock Text="Repeat This Workout" />
                    </StackPanel>
                </Button>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
