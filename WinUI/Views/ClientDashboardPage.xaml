<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinUI.Views.ClientDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:WinUI.Extensions"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Page.Resources>
        <local:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Page.Resources>

    <Page.Transitions>
        <TransitionCollection>
            <NavigationThemeTransition />
        </TransitionCollection>
    </Page.Transitions>

    <Grid>
        <!-- Left-align content: narrow MaxWidth inside ScrollViewer is centered by default and leaves a huge gap next to the nav pane. -->
        <ScrollViewer
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalContentAlignment="Left"
            VerticalContentAlignment="Top">
            <StackPanel
                Padding="20,20,28,32"
                Spacing="28"
                HorizontalAlignment="Stretch">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition IsStaggeringEnabled="True" />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <!-- Header row -->
                <Grid>
                    <TextBlock
                        Text="Analytics Dashboard"
                        Style="{StaticResource TitleTextBlockStyle}"
                        VerticalAlignment="Center" />

                </Grid>

                <InfoBar
                    x:Name="ProgressionInfoBar"
                    Title="Progression update"
                    Severity="Informational"
                    IsOpen="False"
                    IsClosable="True" />

                <!-- KPI Summary Cards -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="20">

                    <!-- Total Workouts -->
                    <Border
                        Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="24">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Total Workouts"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <FontIcon Grid.Column="1" Glyph="&#xE81E;" FontSize="16"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            </Grid>
                            <TextBlock Grid.Row="1" Text="{Binding ViewModel.TotalWorkouts, Mode=OneWay}"
                                       Style="{StaticResource TitleLargeTextBlockStyle}"
                                       Margin="0,12,0,0" />
                        </Grid>
                    </Border>

                    <!-- Active Time (7 Days) -->
                    <Border
                        Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="24">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Active Time (7 Days)"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <FontIcon Grid.Column="1" Glyph="&#xE121;" FontSize="16"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            </Grid>
                            <TextBlock Grid.Row="1" Text="{Binding ViewModel.ActiveTimeSevenDaysDisplay, Mode=OneWay}"
                                       Style="{StaticResource TitleLargeTextBlockStyle}"
                                       Margin="0,12,0,0" />
                        </Grid>
                    </Border>

                    <!-- Preferred Workout -->
                    <Border
                        Grid.Column="2"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="24">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Preferred Workout"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <FontIcon Grid.Column="1" Glyph="&#xE734;" FontSize="16"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            </Grid>
                            <TextBlock Grid.Row="1" Text="{Binding ViewModel.PreferredWorkoutDisplay, Mode=OneWay}"
                                       Style="{StaticResource TitleTextBlockStyle}"
                                       Margin="0,16,0,0"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </Border>
                </Grid>

                <!-- Consistency Chart (control added in code-behind; hidden when empty) -->
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="24"
                    Visibility="{Binding ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="4-Week Consistency"
                                       Style="{StaticResource SubtitleTextBlockStyle}" />
                            <ProgressRing
                                HorizontalAlignment="Right"
                                IsActive="{Binding ViewModel.IsLoadingChart, Mode=OneWay}"
                                Visibility="{Binding ViewModel.IsLoadingChart, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                Width="20" Height="20" />
                        </Grid>

                        <Grid x:Name="ChartContainer" Height="240" Margin="0,16,0,0" />
                    </StackPanel>
                </Border>

                <!-- Workout History -->
                <StackPanel Spacing="16">
                    <TextBlock Text="Workout History"
                               Style="{StaticResource SubtitleTextBlockStyle}" />

                    <!-- Header Row for the history list -->
                    <Grid Padding="16,8" Margin="0,0,48,0" ColumnDefinitions="2*,*,*,Auto"
                          Visibility="{Binding ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                        <TextBlock Text="WORKOUT" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="DATE" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="2" Text="DURATION" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="3" Text="INTENSITY" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" MinWidth="90" Margin="16,0,0,0" />
                    </Grid>

                    <ItemsRepeater
                        ItemsSource="{Binding ViewModel.HistoryItems, Mode=OneWay}"
                        Visibility="{Binding ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Expander
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    CornerRadius="4"
                                    Margin="0,0,0,8">
                                    <Expander.Header>
                                        <Grid ColumnDefinitions="2*,*,*,Auto" Padding="0,8">
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <FontIcon Glyph="&#xE14C;" FontSize="16" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                                <TextBlock Text="{Binding WorkoutName}"
                                                           Style="{StaticResource BodyStrongTextBlockStyle}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>

                                            <TextBlock Grid.Column="1" Text="{Binding CreatedDate}"
                                                       Style="{StaticResource BodyTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding DurationDisplay}"
                                                       Style="{StaticResource BodyTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding IntensityLevel}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                                       VerticalAlignment="Center"
                                                       MinWidth="90"
                                                       Margin="16,0,0,0" />
                                        </Grid>
                                    </Expander.Header>
                                    <Expander.Content>
                                        <StackPanel Padding="0,4,0,12" Spacing="12">
                                            <!-- Exercise List -->
                                            <ItemsControl ItemsSource="{Binding Exercises, Mode=OneWay}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="44,0,0,16">
                                                            <TextBlock Text="{Binding ExerciseName}"
                                                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                                                       Margin="0,0,0,8" />
                                                            <Grid ColumnDefinitions="*,*,*" Margin="0,0,0,6">
                                                                <TextBlock Text="Set" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                                <TextBlock Grid.Column="1" Text="Reps" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                                <TextBlock Grid.Column="2" Text="Weight" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                            </Grid>
                                                            <ItemsControl ItemsSource="{Binding Sets, Mode=OneWay}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Grid ColumnDefinitions="*,*,*" Padding="0,3">
                                                                            <TextBlock Text="{Binding SetNumber}" Style="{StaticResource BodyTextBlockStyle}" />
                                                                            <TextBlock Grid.Column="1" Text="{Binding RepetitionsDisplay}" Style="{StaticResource BodyTextBlockStyle}" />
                                                                            <TextBlock Grid.Column="2" Text="{Binding WeightDisplay}" Style="{StaticResource BodyTextBlockStyle}" />
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Expander.Content>
                                </Expander>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <!-- Loading spinner for history -->
                    <ProgressRing
                        IsActive="{Binding ViewModel.IsLoadingHistory, Mode=OneWay}"
                        Visibility="{Binding ViewModel.IsLoadingHistory, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                        Width="32" Height="32"
                        HorizontalAlignment="Center"
                        Margin="0,16" />

                    <!-- Empty state -->
                    <StackPanel
                        Visibility="{Binding ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                        HorizontalAlignment="Center"
                        Spacing="16"
                        Padding="0,48">
                        <FontIcon Glyph="&#xE787;" FontSize="56"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                  HorizontalAlignment="Center" />
                        <TextBlock Text="No workouts recorded yet"
                                   Style="{StaticResource TitleTextBlockStyle}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Complete a workout to see your analytics and history here."
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Pagination controls -->
                    <Grid
                        ColumnDefinitions="Auto,*,Auto"
                        Margin="0,16,0,0"
                        Visibility="{Binding ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                        <Button Content="Previous"
                                Command="{Binding ViewModel.PreviousPageCommand}"
                                IsEnabled="{Binding ViewModel.CanGoPrevious, Mode=OneWay}">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE76B;" FontSize="12" />
                                        <TextBlock Text="Previous" />
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ViewModel.PageDisplayText, Mode=OneWay}"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="2"
                                Command="{Binding ViewModel.NextPageCommand}"
                                IsEnabled="{Binding ViewModel.CanGoNext, Mode=OneWay}">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Next" />
                                        <FontIcon Glyph="&#xE76C;" FontSize="12" />
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                    </Grid>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
