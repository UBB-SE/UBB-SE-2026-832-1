<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinUI.Views.WorkoutLog.FocusModeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    MinWidth="500">

    <Grid
        Background="#FF000000"
        Padding="40"
        CornerRadius="12">

        <StackPanel Spacing="32" HorizontalAlignment="Center">

            <StackPanel Spacing="4" HorizontalAlignment="Center">
                <TextBlock
                    Text="WORKOUT TIME"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="#99FFFFFF"
                    CharacterSpacing="150"
                    HorizontalAlignment="Center" />
                <TextBlock
                    Text="{x:Bind ViewModel.WorkoutElapsedDisplay, Mode=OneWay}"
                    FontSize="80"
                    FontWeight="Bold"
                    FontFamily="Consolas"
                    Foreground="#FF6AB4FF"
                    CharacterSpacing="20"
                    HorizontalAlignment="Center" />
                <TextBlock
                    Text="{x:Bind ViewModel.WorkoutSessionTitle, Mode=OneWay}"
                    FontSize="14"
                    Foreground="#99FFFFFF"
                    HorizontalAlignment="Center" />
            </StackPanel>

            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <TextBlock
                    Text="CURRENT EXERCISE"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Foreground="#66FFFFFF"
                    CharacterSpacing="150"
                    HorizontalAlignment="Center" />
                <TextBlock
                    Text="{x:Bind ViewModel.CurrentExerciseName, Mode=OneWay}"
                    FontSize="28"
                    FontWeight="Bold"
                    Foreground="White"
                    HorizontalAlignment="Center" />
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <TextBlock
                        Text="Set"
                        FontSize="16"
                        Foreground="#99FFFFFF" />
                    <TextBlock
                        Text="{x:Bind ViewModel.CurrentSetNumber, Mode=OneWay}"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="White" />
                    <TextBlock
                        Text="·"
                        FontSize="16"
                        Foreground="#66FFFFFF" />
                    <TextBlock
                        Text="Target:"
                        FontSize="16"
                        Foreground="#99FFFFFF" />
                    <TextBlock
                        Text="{x:Bind ViewModel.CurrentTargetReps, Mode=OneWay}"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="White" />
                    <TextBlock
                        Text="reps"
                        FontSize="16"
                        Foreground="#99FFFFFF" />
                </StackPanel>
            </StackPanel>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="24" HorizontalAlignment="Center" Width="320">
                <StackPanel Spacing="8">
                    <TextBlock
                        Text="REPS"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="#66FFFFFF"
                        CharacterSpacing="150"
                        HorizontalAlignment="Center" />
                    <NumberBox
                        Value="{x:Bind ViewModel.CurrentSetRepsInput, Mode=TwoWay}"
                        Minimum="0" Maximum="999"
                        SpinButtonPlacementMode="Inline"
                        PlaceholderText="0"
                        HorizontalAlignment="Stretch" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="8">
                    <TextBlock
                        Text="WEIGHT (KG)"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="#66FFFFFF"
                        CharacterSpacing="150"
                        HorizontalAlignment="Center" />
                    <NumberBox
                        Value="{x:Bind ViewModel.CurrentSetWeightInput, Mode=TwoWay}"
                        Minimum="0" Maximum="9999"
                        SmallChange="0.5"
                        SpinButtonPlacementMode="Inline"
                        PlaceholderText="0"
                        HorizontalAlignment="Stretch" />
                </StackPanel>
            </Grid>

            <Button
                Content="Complete Set"
                Style="{StaticResource AccentButtonStyle}"
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.CompleteCurrentSetCommand}" />

            <StackPanel
                Spacing="8"
                HorizontalAlignment="Center"
                Visibility="{x:Bind ViewModel.IsResting, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <TextBlock
                    Text="REST TIME"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Foreground="#66FFFFFF"
                    CharacterSpacing="150"
                    HorizontalAlignment="Center" />
                <TextBlock
                    Text="{x:Bind ViewModel.RestTimeRemaining, Mode=OneWay}"
                    FontSize="48"
                    FontWeight="Bold"
                    FontFamily="Consolas"
                    Foreground="#FF6AB4FF"
                    HorizontalAlignment="Center" />
                <TextBlock
                    Text="seconds remaining"
                    FontSize="13"
                    Foreground="#99FFFFFF"
                    HorizontalAlignment="Center" />
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>
