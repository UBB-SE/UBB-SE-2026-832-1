<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinUI.Views.WorkoutLog.FocusModeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:WinUI.ViewModels"
    mc:Ignorable="d"
    Width="280">

    <Grid
        Background="#FF000000"
        Padding="20"
        CornerRadius="12">

        <StackPanel Spacing="20" HorizontalAlignment="Stretch">

            <StackPanel Spacing="6" HorizontalAlignment="Center">
                <TextBlock
                    Text="{x:Bind ViewModel.WorkoutSessionTitle, Mode=OneWay}"
                    FontSize="22"
                    FontWeight="Bold"
                    Foreground="White"
                    HorizontalAlignment="Center" />
                <TextBlock
                    Text="SESSION TIME"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="#99FFFFFF"
                    CharacterSpacing="150"
                    HorizontalAlignment="Center" />
                <TextBlock
                    Text="{x:Bind ViewModel.WorkoutElapsedDisplay, Mode=OneWay}"
                    FontSize="36"
                    FontWeight="Bold"
                    FontFamily="Consolas"
                    Foreground="#FF22C55E"
                    CharacterSpacing="20"
                    HorizontalAlignment="Center" />
            </StackPanel>

            <Border
                Background="#11FFFFFF"
                BorderBrush="#22FFFFFF"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,10">
                <StackPanel Spacing="2">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock
                            Text="Now"
                            FontSize="10"
                            Foreground="#99FFFFFF"
                            VerticalAlignment="Center" />
                        <TextBlock
                            Text="{x:Bind ViewModel.CurrentExerciseName, Mode=OneWay}"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="White"
                            VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Set" FontSize="11" Foreground="#99FFFFFF" />
                        <TextBlock
                            Text="{x:Bind ViewModel.CurrentSetNumber, Mode=OneWay}"
                            FontSize="11"
                            FontWeight="Bold"
                            Foreground="White" />
                        <TextBlock Text="·" FontSize="11" Foreground="#66FFFFFF" />
                        <TextBlock Text="Target" FontSize="11" Foreground="#99FFFFFF" />
                        <TextBlock
                            Text="{x:Bind ViewModel.CurrentTargetReps, Mode=OneWay}"
                            FontSize="11"
                            FontWeight="Bold"
                            Foreground="White" />
                        <TextBlock Text="reps" FontSize="11" Foreground="#99FFFFFF" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel Spacing="8">
                <TextBlock
                    Text="Complete Current Set"
                    FontSize="13"
                    FontWeight="Bold"
                    Foreground="White" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <TextBox
                        Text="{x:Bind ViewModel.CurrentSetRepsInputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Reps"
                        InputScope="Number" />
                    <TextBox
                        Grid.Column="1"
                        Text="{x:Bind ViewModel.CurrentSetWeightInputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Weight"
                        InputScope="Number" />
                </Grid>
                <Button
                    Content="Complete Set"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.CompleteCurrentSetCommand}" />
            </StackPanel>

            <StackPanel
                Spacing="6"
                Visibility="{x:Bind ViewModel.CurrentExercise, Mode=OneWay, Converter={StaticResource NullToVisibility}}">
                <TextBlock
                    Text="{x:Bind ViewModel.CurrentExerciseName, Mode=OneWay}"
                    FontSize="14"
                    FontWeight="Bold"
                    Foreground="White" />
                <ItemsRepeater
                    ItemsSource="{x:Bind ViewModel.CurrentExercise.Sets, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:ActiveSetViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                                <TextBlock Text="Set" FontSize="12" Foreground="#99FFFFFF" />
                                <TextBlock
                                    Text="{x:Bind SetIndex}"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="White" />
                                <TextBlock Text="·" FontSize="12" Foreground="#66FFFFFF" />
                                <TextBlock
                                    Text="{x:Bind TargetReps}"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="White" />
                                <TextBlock Text="reps" FontSize="12" Foreground="#99FFFFFF" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>

            <Button
                Content="Exit Focus Mode"
                Style="{StaticResource AccentButtonStyle}"
                HorizontalAlignment="Stretch"
                Click="ExitButton_Click" />

            <StackPanel
                Spacing="4"
                HorizontalAlignment="Center"
                Visibility="{x:Bind ViewModel.IsResting, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <TextBlock
                    Text="REST TIME"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="#66FFFFFF"
                    CharacterSpacing="150"
                    HorizontalAlignment="Center" />
                <TextBlock
                    Text="{x:Bind ViewModel.RestTimeRemaining, Mode=OneWay}"
                    FontSize="24"
                    FontWeight="Bold"
                    FontFamily="Consolas"
                    Foreground="#FF6AB4FF"
                    HorizontalAlignment="Center" />
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>
