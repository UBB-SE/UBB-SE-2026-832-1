<Page
    x:Class="WinUI.Views.UserView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Account" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,16"/>

        <TextBlock
            Grid.Row="1"
            Text="{Binding StatusMessage}"
            Foreground="Red"
            TextWrapping="Wrap"
            Margin="0,0,0,12"/>

        <Pivot Grid.Row="2" x:Name="AuthPivot">
            <PivotItem Header="Login">
                <StackPanel Spacing="12" MaxWidth="400" HorizontalAlignment="Left" Margin="0,16,0,0">
                    <TextBox
                        Header="Username"
                        Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Enter your username"/>

                    <PasswordBox
                        Header="Password"
                        Password="{Binding Password, Mode=TwoWay}"
                        PlaceholderText="Enter your password"/>

                    <Button
                        Content="Login"
                        Command="{Binding OnLoginCommand}"
                        Style="{ThemeResource AccentButtonStyle}"
                        HorizontalAlignment="Stretch"/>
                </StackPanel>
            </PivotItem>

            <PivotItem Header="Register">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12" MaxWidth="400" HorizontalAlignment="Left" Margin="0,16,0,0">
                        <TextBox
                            Header="Username"
                            Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="Choose a username"/>

                        <PasswordBox
                            Header="Password"
                            Password="{Binding Password, Mode=TwoWay}"
                            PlaceholderText="Choose a password"/>

                        <CheckBox
                            Content="Register as Nutritionist"
                            IsChecked="{Binding IsNutritionistChecked, Mode=TwoWay}"/>

                        <DatePicker
                            Header="Date of Birth"
                            Date="{Binding SelectedDate, Mode=TwoWay}"/>

                        <NumberBox
                            Header="Weight (kg)"
                            Value="{Binding Weight, Mode=TwoWay}"
                            Minimum="1"
                            SpinButtonPlacementMode="Inline"/>

                        <NumberBox
                            Header="Height (cm)"
                            Value="{Binding Height, Mode=TwoWay}"
                            Minimum="1"
                            SpinButtonPlacementMode="Inline"/>

                        <ComboBox
                            Header="Gender"
                            x:Name="GenderComboBox"
                            SelectedItem="{Binding Gender, Mode=TwoWay}"
                            PlaceholderText="Select gender"
                            HorizontalAlignment="Stretch">
                            <x:String>Male</x:String>
                            <x:String>Female</x:String>
                        </ComboBox>

                        <ComboBox
                            Header="Goal"
                            x:Name="GoalComboBox"
                            SelectedItem="{Binding Goal, Mode=TwoWay}"
                            PlaceholderText="Select goal"
                            HorizontalAlignment="Stretch">
                            <x:String>Lose Weight</x:String>
                            <x:String>Maintain</x:String>
                            <x:String>Gain Muscle</x:String>
                        </ComboBox>

                        <Button
                            Content="Register"
                            Command="{Binding OnRegisterCommand}"
                            Style="{ThemeResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Margin="0,8,0,0"/>

                        <Button
                            Content="Save Profile Data"
                            Command="{Binding OnSaveDataCommand}"
                            HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
