<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinUI.Views.ClientProfileView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:ClassLibrary.Models"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="{Binding CaloriesSummary, Mode=OneWay}" FontSize="14" />
            <TextBlock Text="{Binding LatestSessionHint, Mode=OneWay}" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Sync calories to nutrition API" Command="{Binding SyncNutritionCommand}" />
                <TextBlock Text="{Binding SyncNutritionStatus, Mode=OneWay}" VerticalAlignment="Center" FontSize="12" TextWrapping="Wrap" />
            </StackPanel>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Grid.Column="0" Padding="0,0,12,0">
            <StackPanel>
                <TextBlock Text="Latest workout exercises" FontSize="24" FontWeight="Bold" Margin="0,0,0,12"/>

                <ItemsRepeater ItemsSource="{Binding LoggedExercises}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:LoggedExercise">
                            <Expander Header="{Binding Name}" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Foreground="Gray" FontStyle="Italic"/>
                                    <TextBlock Text="{Binding MuscleGroup}" />

                                    <ItemsRepeater ItemsSource="{Binding Sets}">
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="models:LoggedSet">
                                                <StackPanel Orientation="Horizontal" Margin="8,2">
                                                    <TextBlock Text="{Binding Id}" Width="30"/>
                                                    <TextBlock Text="{Binding TargetReps}" Width="50"/>
                                                    <TextBlock Text="{Binding ActualReps}" Width="50"/>
                                                    <TextBlock Text="{Binding ActualWeight}" Width="60"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>
                            </Expander>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </ScrollViewer>

        <ScrollViewer Grid.Row="1" Grid.Column="1" Padding="12,0,0,0">
            <StackPanel>
                <TextBlock Text="Nutrition Plan" FontSize="24" FontWeight="Bold" Margin="0,0,0,12"/>

                <ItemsRepeater ItemsSource="{Binding Meals}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:Meal">
                            <Expander Header="{Binding Name}" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Ingredients:" FontWeight="Bold" />
                                    <ItemsRepeater ItemsSource="{Binding Ingredients}">
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <TextBlock Text="{Binding}" Margin="12,0"/>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                    <TextBlock Text="Instructions:" FontWeight="Bold" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding Instructions}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Expander>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
