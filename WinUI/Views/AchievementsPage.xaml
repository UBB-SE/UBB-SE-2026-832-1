<Page
    x:Class="WinUI.Views.AchievementsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:ClassLibrary.Models"
    xmlns:extensions="using:WinUI.Extensions"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <extensions:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <Page.Transitions>
        <TransitionCollection>
            <NavigationThemeTransition />
        </TransitionCollection>
    </Page.Transitions>

    <Grid RowDefinitions="Auto,*">

        <Border
            Grid.Row="0"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1"
            Padding="24,20">
            <StackPanel Spacing="4">
                <TextBlock
                    Text="Achievements"
                    Style="{ThemeResource TitleTextBlockStyle}" />
                <TextBlock
                    Text="Track your progress and review the milestones you have unlocked."
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Border>

        <ScrollViewer
            Grid.Row="1"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled">
            <StackPanel Padding="24,24,24,40" Spacing="16">

                <StackPanel
                    HorizontalAlignment="Center"
                    Spacing="12"
                    Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ProgressRing IsActive="True" Width="40" Height="40" />
                    <TextBlock
                        Text="Loading achievements..."
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        HorizontalAlignment="Center" />
                </StackPanel>

                <TextBlock
                    Text="No achievements available yet."
                    Style="{ThemeResource BodyTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center"
                    Visibility="{x:Bind ViewModel.Achievements.Count, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}" />

                <ItemsRepeater
                    ItemsSource="{x:Bind ViewModel.Achievements, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout
                            MinItemWidth="220"
                            MinItemHeight="240"
                            MinRowSpacing="16"
                            MinColumnSpacing="16"
                            ItemsStretch="Fill" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:Achievement">
                            <Border
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="20">
                                <StackPanel Spacing="12" HorizontalAlignment="Center">
                                    <Border
                                        Width="64"
                                        Height="64"
                                        CornerRadius="32"
                                        HorizontalAlignment="Center"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}">
                                        <FontIcon
                                            Glyph="{x:Bind Icon}"
                                            FontSize="28"
                                            Foreground="White"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />
                                    </Border>

                                    <TextBlock
                                        Text="{x:Bind Name}"
                                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                                        HorizontalAlignment="Center"
                                        TextAlignment="Center"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Text="{x:Bind Description}"
                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        HorizontalAlignment="Center"
                                        TextAlignment="Center"
                                        TextWrapping="Wrap" />

                                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                                        <TextBlock
                                            Text="Criteria"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            FontWeight="SemiBold"
                                            HorizontalAlignment="Center" />
                                        <TextBlock
                                            Text="{x:Bind Criteria}"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            HorizontalAlignment="Center"
                                            TextAlignment="Center"
                                            TextWrapping="Wrap" />
                                    </StackPanel>

                                    <TextBlock
                                        Text="{x:Bind ThresholdWorkouts, Mode=OneWay}"
                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        HorizontalAlignment="Center"
                                        TextAlignment="Center"
                                        Visibility="{x:Bind ThresholdWorkouts.HasValue, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>