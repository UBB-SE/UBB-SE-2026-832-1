<Page
    x:Class="WinUI.Views.CalendarIntegrationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24">
        <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Left">
            <TextBlock Text="Calendar Integration" Style="{ThemeResource TitleTextBlockStyle}"/>

            <TextBlock Text="Set up your workout calendar by selecting your workout, duration, and the days you want to train." TextWrapping="Wrap" />

            <InfoBar x:Name="StatusInfoBar" IsOpen="False" Margin="0,0,0,8"/>

            <ComboBox
                x:Name="WorkoutComboBox"
                Header="Select Workout"
                PlaceholderText="Choose a workout program"
                HorizontalAlignment="Stretch"
                ItemsSource="{Binding AvailableWorkouts}"
                SelectedItem="{Binding SelectedWorkout, Mode=TwoWay}"
                DisplayMemberPath="Name"/>

            <TextBox
                x:Name="DurationWeeksTextBox"
                Header="Schedule Duration (Weeks)"
                PlaceholderText="Enter weeks (1-52)"
                HorizontalAlignment="Stretch"
                InputScope="Number"
                Text="{Binding DurationWeeks, Mode=TwoWay}"/>

            <TextBlock Text="Training Days" />
            <ItemsControl ItemsSource="{Binding SelectedDays}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ToggleButton Content="{Binding DayName}" IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button
                x:Name="GenerateCalendarButton"
                Content="Generate Calendar"
                Style="{ThemeResource AccentButtonStyle}"
                HorizontalAlignment="Stretch"
                Margin="0,16,0,0"/>
        </StackPanel>
    </Grid>
</Page>
