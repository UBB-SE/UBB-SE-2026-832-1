<Page
    x:Class="WinUI.Views.RegisterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F5F5F5">

	<Grid>
		<Border Width="400" Background="White" CornerRadius="8" Padding="40"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                BorderBrush="#E0E0E0" BorderThickness="1">
			<StackPanel Spacing="20">
				<TextBlock Text="Register" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

				<StackPanel Spacing="8">
					<TextBlock Text="Username" />
					<TextBox Text="{x:Bind ViewModel.Username, Mode=TwoWay}" PlaceholderText="Enter your username" />
				</StackPanel>

				<StackPanel Spacing="8">
					<TextBlock Text="Password" />
					<PasswordBox Password="{x:Bind ViewModel.Password, Mode=TwoWay}" PlaceholderText="Enter your password" />
				</StackPanel>

				<StackPanel Spacing="8">
					<TextBlock Text="Role" />
					<ComboBox ItemsSource="{x:Bind ViewModel.Roles}" SelectedItem="{x:Bind ViewModel.SelectedRole, Mode=TwoWay}" HorizontalAlignment="Stretch" />
				</StackPanel>

				<Button Content="Register" Command="{x:Bind ViewModel.RegisterCommand}"
                        Background="#0066CC" Foreground="White" HorizontalAlignment="Stretch" Margin="0,20,0,0"/>

				<HyperlinkButton Content="Already have an account? Login."
                                 Command="{x:Bind ViewModel.GoToLoginCommand}"
                                 HorizontalAlignment="Center" />
			</StackPanel>
		</Border>
	</Grid>
</Page>
