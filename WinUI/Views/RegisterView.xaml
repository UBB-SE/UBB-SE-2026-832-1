<Page
    x:Class="WinUI.Views.RegisterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F5F5F5">

    <Grid>
        <Border Width="400" Background="White" CornerRadius="8" Padding="40"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                BorderBrush="#CCCCCC" BorderThickness="1">
            <StackPanel Spacing="20">
                <TextBlock Text="Register" FontSize="28" FontWeight="SemiBold" 
                           Foreground="Black" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <StackPanel Spacing="8">
                    <TextBlock Text="Username" Foreground="Black" />
                    <TextBox Text="{x:Bind ViewModel.UserName, Mode=TwoWay}" 
                             PlaceholderText="Enter your username" 
                             Foreground="Black" BorderBrush="#999999" />
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="Password" Foreground="Black" />
                    <PasswordBox Password="{x:Bind ViewModel.Password, Mode=TwoWay}" 
                                 PlaceholderText="Enter your password" 
                                 Foreground="Black" BorderBrush="#999999" />
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="Role (Leave unchecked for Client)" Foreground="Black" />
                    <CheckBox Content="Trainer" IsChecked="{x:Bind ViewModel.IsTrainer, Mode=TwoWay}" Foreground="Black" />
                    <CheckBox Content="Nutritionist" IsChecked="{x:Bind ViewModel.IsNutritionist, Mode=TwoWay}" Foreground="Black" />
                </StackPanel>

                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" 
                           Foreground="Red" HorizontalAlignment="Center" TextWrapping="Wrap" />

                <Button Content="Register" Command="{x:Bind ViewModel.RegisterCommand}"
                        Background="#0066CC" Foreground="White" HorizontalAlignment="Stretch" Margin="0,10,0,0"/>

                <HyperlinkButton Content="Already have an account? Login."
                                 Command="{x:Bind ViewModel.GoToLoginCommand}"
                                 Foreground="#0066CC" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
