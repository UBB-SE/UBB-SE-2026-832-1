@using ClassLibrary.Proxies.Interfaces
@inject IUserSession userSession
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>WebUI Management System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body>
    <header class="container mt-4">
        <ul class="nav nav-tabs">
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" && ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")" 
                   asp-area="" asp-controller="Home" asp-action="Index">Dashboard</a>
            </li>
            @if (userSession.IsClient)
            {
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" && ViewContext.RouteData.Values["Controller"]?.ToString() == "CalendarIntegration" ? "active" : "")" 
                       asp-area="" asp-controller="CalendarIntegration" asp-action="Index">Calendar Integration</a>
                </li>
            }
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Products" ? "active" : "")"
                   asp-area="" asp-controller="Products" asp-action="Index">Products</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "MealPlan" ? "active" : "")"
                   asp-area="" asp-controller="MealPlan" asp-action="Index">Meal Plan</a>
            </li>
            @if (UserSession.IsClient)
            {
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Workout" ? "active" : "")"
                       asp-area="" asp-controller="Workout" asp-action="Index">Workout History</a>
                </li>
            }
        </ul>
    </header>

    <main class="container mt-3">
        <div class="tab-content border-start border-end border-bottom p-4 bg-light rounded-bottom">
            @RenderBody()
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
