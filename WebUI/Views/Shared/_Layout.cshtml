@using ClassLibrary.Proxies.Interfaces
@inject IUserSession UserSession
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebUI Management System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="container mt-4">
        <ul class="nav nav-tabs">
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")"
                   asp-area="" asp-controller="Home" asp-action="Index">Dashboard</a>
            </li>
            @if (UserSession.IsClient && UserSession.CurrentClientId > 0)
            {
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "ClientDashboard" ? "active" : "")"
                       asp-area="" asp-controller="ClientDashboard" asp-action="Index">Analytics Dashboard</a>
                </li>
            }
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Products" ? "active" : "")"
                   asp-area="" asp-controller="Products" asp-action="Index">Products</a>
            </li>
        </ul>
    </header>

    <main class="container mt-3">
        <div class="tab-content border-start border-end border-bottom p-4 bg-light rounded-bottom">
            @RenderBody()
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
